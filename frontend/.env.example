# Baloney — Environment Variables
# Copy this file to .env.local: cp .env.example .env.local

# Supabase — find these in your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# HuggingFace (fallback for AI detection if Railway is unavailable)
HUGGINGFACE_API_KEY=

# Railway Backend (self-hosted DeBERTa — preferred for text detection)
# Deploy backend/ to Railway, then set this URL
RAILWAY_BACKEND_URL=

# Pangram API (text detection, 99.85% accuracy)
PANGRAM_API_KEY=

# SightEngine API (image + video AI detection, 2000 free ops/month)
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=

# Reality Defender (deepfake escalation, 50 free/month)
REALITY_DEFENDER_API_KEY=

# Google Cloud (SynthID Image via Vertex AI)
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_REGION=us-central1
GOOGLE_CLOUD_API_KEY=
