# Baloney — Environment Variables
# Copy this file to .env.local: cp .env.example .env.local
# All values below are placeholders — replace with your actual keys
#
# For the open-source community edition, you only need Supabase keys.
# Premium API keys are optional — detection cascades to local-only when absent.
# Manage ALL production secrets via Vercel Dashboard > Settings > Environment Variables.

# ──────────────────────────────────────────────
# Edition (controls feature tier)
# "community" = open-source, local-only detection
# "pro" = full ensemble with premium APIs
# If unset, auto-detects based on available API keys
# ──────────────────────────────────────────────
BALONEY_EDITION=community

# ──────────────────────────────────────────────
# Supabase (REQUIRED)
# ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ──────────────────────────────────────────────
# HuggingFace Inference API (server-side only)
# Used for AI text detection (RoBERTa ensemble)
# Get a key at: https://huggingface.co/settings/tokens
# ──────────────────────────────────────────────
HUGGINGFACE_API_KEY="your-huggingface-api-key"

# ──────────────────────────────────────────────
# Pangram API (text detection, 99.85% accuracy)
# Get a key at: https://pangram.com
# ──────────────────────────────────────────────
PANGRAM_API_KEY="your-pangram-api-key"

# ──────────────────────────────────────────────
# SightEngine API (image + video AI detection)
# 2000 free ops/month — https://sightengine.com
# ──────────────────────────────────────────────
SIGHTENGINE_API_USER="your-sightengine-user"
SIGHTENGINE_API_SECRET="your-sightengine-secret"

# ──────────────────────────────────────────────
# Seed endpoint protection (REQUIRED for /api/seed)
# Generate with: openssl rand -hex 32
# ──────────────────────────────────────────────
SEED_SECRET="your-seed-secret"

# ──────────────────────────────────────────────
# Optional: Reality Defender (deepfake escalation)
# 50 free/month — https://realitydefender.com
# ──────────────────────────────────────────────
REALITY_DEFENDER_API_KEY=

# ──────────────────────────────────────────────
# Optional: Google Cloud (SynthID Image via Vertex AI)
# ──────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_REGION=us-central1
GOOGLE_CLOUD_API_KEY=
GOOGLE_SERVICE_ACCOUNT_JSON=

# ──────────────────────────────────────────────
# Optional: Railway backend (SynthID Text watermark detection)
# Self-hosted Python service running Google SynthID text detector
# ──────────────────────────────────────────────
RAILWAY_BACKEND_URL=
