{
  "manifest_version": 3,
  "name": "Baloney — AI Content Detector",
  "version": "0.5.0",
  "description": "Detect AI-generated images and text as you scroll. Personal analytics dashboard included.",
  "minimum_chrome_version": "114",

  "permissions": [
    "storage",
    "activeTab",
    "contextMenus",
    "sidePanel"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": ["config.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "commands": {
    "scan-selected-text": {
      "suggested_key": { "default": "Alt+B", "mac": "Alt+B" },
      "description": "Scan selected text with Baloney"
    }
  }
}
